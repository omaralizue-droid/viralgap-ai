# ==============================================================================
#                 VIRALGAP PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Use this template as a baseline for deploying to Vercel, Docker, or Cloud Run.
# Copy this file to .env in your local environment, or configure these variables
# directly inside the Vercel Dashboard -> Settings -> Environment Variables.
# Do NOT commit secrets to your public repository!

# ------------------------------------------------------------------------------
# 1. GOOGLE GEMINI AI CONFIGURATION
# ------------------------------------------------------------------------------
# Required for trend scanner, content gap analysis, and AI-powered copilot.
# Obtain from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# 2. SUPABASE AUTH & PERSISTENT DATABASE
# ------------------------------------------------------------------------------
# Required for user sessions, saving research trends, and historic logs.
# Obtain from: https://supabase.com/ -> Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here

# ------------------------------------------------------------------------------
# 3. STRIPE SUBSCRIPTION & BILLING INTEGRATION
# ------------------------------------------------------------------------------
# Required to enable simulated or real premium checkout tiers and portals.
# Obtain from: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_PUBLISHABLE_KEY=pk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs corresponding to Subscription Tiers
# Configured in Stripe Dashboard under Product Catalog
STRIPE_PRICE_CREATOR=price_1...
STRIPE_PRICE_PRO=price_2...
STRIPE_PRICE_AGENCY=price_3...

# ------------------------------------------------------------------------------
# 4. YOUTUBE API INTEGRATION (OPTIONAL)
# ------------------------------------------------------------------------------
# Configured to enable YouTube analytics fetching, search grounding, or video validation.
# Create credentials in: https://console.cloud.google.com/
YOUTUBE_API_KEY=your_google_developer_youtube_api_key
YOUTUBE_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_oauth_client_secret

# ------------------------------------------------------------------------------
# 5. OFFLINE MOCK MODE (FEATURE FLAG)
# ------------------------------------------------------------------------------
# Set to true to bypass external Gemini and YouTube API calls, using local 
# realistic context-aware mock generators instead. Fully testable without keys.
USE_MOCK_APIS=true
